# ============================================================
# FreeRADIUS Manager - Environment Configuration
# Copy this file to .env and update all values before deploying
# ============================================================

# ---- Database ----
DB_HOST=postgres
DB_PORT=5432
DB_USER=radius_user
DB_PASSWORD=ChangeMe_Secure_Pass123!
DB_NAME=radius
DB_SSL_MODE=disable

# ---- JWT Authentication ----
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-64-chars
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=168h

# ---- RADIUS Server ----
RADIUS_HOST=freeradius
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=testing123-please-change-to-32-char-minimum-in-production
RADIUS_TIMEOUT=5s
RADIUS_RETRIES=3

# ---- Web Interface ----
WEB_PORT=8081
VITE_API_URL=http://localhost:8088

# ---- Security ----
ADMIN_IP_WHITELIST=0.0.0.0/0
SESSION_TIMEOUT=3600
SESSION_CONCURRENT_BLOCK=5m
BCRYPT_COST=12
RATE_LIMIT=100
BRUTE_FORCE_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT=15

# ---- Application ----
APP_ENV=production

# ---- Email (Optional) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@radius-manager.com

# ---- Backup ----
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
